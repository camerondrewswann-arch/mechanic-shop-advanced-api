{
  "info": {
    "name": "Mechanic Shop Advanced API",
    "description": "Assignment collection for customer/mechanic authentication, rate limiting, caching, advanced queries, pagination, service tickets, and inventory.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup and Authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/customers/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customers"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Customer\",\n  \"email\": \"postman.customer@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 409) { pm.test(\"Customer available\", () => true); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/customers/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customers",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.customer@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Customer login succeeds\", function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set(\"customer_token\", data.token);",
                  "pm.collectionVariables.set(\"customer_id\", data.customer.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Mechanic",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mechanics/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mechanics"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Mechanic\",\n  \"email\": \"postman.mechanic@example.com\",\n  \"password\": \"wrench123\",\n  \"specialty\": \"Diagnostics\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 409) { pm.test(\"Mechanic available\", () => true); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Mechanic Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mechanics/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mechanics",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.mechanic@example.com\",\n  \"password\": \"wrench123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Mechanic login succeeds\", function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set(\"mechanic_token\", data.token);",
                  "pm.collectionVariables.set(\"mechanic_id\", data.mechanic.id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Customers and Tickets",
      "item": [
        {
          "name": "Paginated Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/customers/?page=1&per_page=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customers",
                "?page=1&per_page=5"
              ]
            }
          }
        },
        {
          "name": "Create Service Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/service-tickets/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "service-tickets"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Postman brake inspection\",\n  \"status\": \"open\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Ticket created\", function () { pm.response.to.have.status(201); });",
                  "pm.collectionVariables.set(\"ticket_id\", pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "My Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/customers/my-tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customers",
                "my-tickets"
              ]
            }
          }
        },
        {
          "name": "Get Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/service-tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "service-tickets",
                "{{ticket_id}}"
              ]
            }
          }
        }
      ]
    },
    {
